{
  "name": "use-mask-input-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Input masks for React. Works with React Hook Form, TanStack Form, Ant Design, and plain inputs.",
  "repository": {
    "url": "https://github.com/eduardoborges/use-mask-input"
  },
  "bugs": {
    "url": "https://github.com/eduardoborges/use-mask-input/issues"
  },
  "homepage": "https://use-mask-input.eduardoborges.dev/",
  "keywords": [
    "react",
    "react-hook-form",
    "tanstack-form",
    "antd",
    "input-mask",
    "input-masking"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=vite-project",
    "dev:tanstack": "turbo run dev --filter=tanstack-form-project",
    "dev:next": "turbo run dev --filter=next-project",
    "dev:docs": "turbo run start --filter=docs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxlint": "1.66.0",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": ">=16",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.7.0"
}