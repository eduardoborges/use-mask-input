{
  "name": "use-mask-input",
  "version": "3.7.4",
  "private": false,
  "description": "A react Hook for build elegant input masks. Compatible with React Hook Form",
  "author": "Eduardo Borges<euduardoborges@gmail.com>",
  "type": "module",
  "repository": {
    "url": "https://github.com/eduardoborges/use-mask-input"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "source": "./src/index.tsx",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./antd": {
      "types": "./dist/antd.d.ts",
      "import": "./dist/antd.js",
      "require": "./dist/antd.cjs"
    }
  },
  "engines": {
    "node": ">=16",
    "npm": ">=7"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint ./src",
    "test": "vitest --dir ./src --run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postbuild": "cp ../../README.md README.md"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/inputmask": "5.0.7",
    "@types/node": "25",
    "@types/react": ">=19",
    "@types/react-dom": ">=19",
    "@vitest/coverage-v8": "4.0.18",
    "antd": "^6.3.2",
    "oxlint": "1.53.0",
    "inputmask": "5.0.10-beta.61",
    "jsdom": "^28.1.0",
    "react-hook-form": "7.71.2",
    "tsup": "8.5.1",
    "typescript": "5.9",
    "vitest": "4.0.18"
  }
}
