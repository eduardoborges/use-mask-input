{
  "name": "use-mask-input",
  "version": "3.10.2",
  "private": false,
  "description": "A react Hook for build elegant input masks. Compatible with React Hook Form",
  "license": "MIT",
  "author": "Eduardo Borges<euduardoborges@gmail.com>",
  "type": "module",
  "repository": {
    "url": "https://github.com/eduardoborges/use-mask-input"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "source": "./src/index.tsx",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./antd": {
      "import": {
        "types": "./dist/antd.d.mts",
        "default": "./dist/antd.mjs"
      },
      "require": {
        "types": "./dist/antd.d.cts",
        "default": "./dist/antd.cjs"
      }
    }
  },
  "engines": {
    "node": ">=16",
    "npm": ">=7"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint ./src",
    "test": "vitest --dir ./src --run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postbuild": "cp ../../README.md README.md"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.*",
    "!dist/*-stats.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "antd": ">=5",
    "react": ">=17",
    "react-dom": ">=17"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "^2.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/inputmask": "5.0.7",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.7",
    "antd": "^6.4.4",
    "inputmask": "5.0.10-beta.61",
    "jsdom": "^29.1.1",
    "oxlint": "1.66.0",
    "react-hook-form": "7.75.0",
    "tsdown": "^0.22.2",
    "typescript": "~6.0.3",
    "vitest": "4.1.7"
  }
}
